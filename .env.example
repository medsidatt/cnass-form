###############################################################################
# Application
###############################################################################
APP_NAME=CNASS
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Africa/Nouakchott

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

###############################################################################
# Logging
###############################################################################
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

###############################################################################
# Database (SQLite default — switch to mysql/pgsql for production scale)
###############################################################################
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=cnass
# DB_USERNAME=cnass
# DB_PASSWORD=

###############################################################################
# Sessions
# SESSION_SECURE_COOKIE must be true in production (HTTPS).
###############################################################################
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

###############################################################################
# Queue / cache / filesystem
###############################################################################
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

###############################################################################
# Mail (used for error notifications if configured)
###############################################################################
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="no-reply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

###############################################################################
# Twilio Verify (WhatsApp OTP)
# - The application uses the Twilio Verify service: it generates and sends
#   the code, and we just check the user's input against the verification.
# - Enable the WhatsApp channel on your Verify service in the Twilio Console.
# - Leave any of these empty to fall back to the local dev code 123456.
###############################################################################
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SID=

###############################################################################
# Admin gate
# Required to access /admin. Use a long random string.
###############################################################################
ADMIN_PASSWORD=

###############################################################################
# AWS (only required if you switch FILESYSTEM_DISK=s3)
###############################################################################
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
