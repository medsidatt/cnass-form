###############################################################################
# CNASS — Production .env template
# Copy to .env on the production server and fill in the secrets.
# IMPORTANT: never commit this file with real values.
###############################################################################

APP_NAME=CNASS
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example
APP_TIMEZONE=Africa/Nouakchott

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=daily
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# --- Database (recommended: mysql or pgsql for production) ---
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=cnass
DB_USERNAME=cnass
DB_PASSWORD=__REPLACE_ME__

# --- Sessions ---
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# --- Queue / cache ---
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# --- Mail ---
MAIL_MAILER=smtp
MAIL_HOST=__REPLACE_ME__
MAIL_PORT=587
MAIL_USERNAME=__REPLACE_ME__
MAIL_PASSWORD=__REPLACE_ME__
MAIL_FROM_ADDRESS="no-reply@your-domain.example"
MAIL_FROM_NAME="${APP_NAME}"

# --- Twilio (WhatsApp OTP) ---
# Use a real WhatsApp Business sender in production, NOT the sandbox.
TWILIO_SID=__REPLACE_ME__
TWILIO_AUTH_TOKEN=__REPLACE_ME__
TWILIO_VERIFY_SID=
TWILIO_WHATSAPP_FROM=whatsapp:+__YOUR_PROD_NUMBER__

# --- Admin gate ---
# Generate a strong random string (e.g. `openssl rand -base64 32`).
ADMIN_PASSWORD=__REPLACE_ME__

VITE_APP_NAME="${APP_NAME}"
